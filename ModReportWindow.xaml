<Window x:Class="FMTool.ModReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mod Analysis Report" Height="680" Width="880"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MinHeight="480" MinWidth="640"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Segoe UI Variable, Segoe UI"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="14" GlassFrameThickness="0" UseAeroCaptionButtons="False" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar drag region -->
            <Border Grid.Row="0" Background="Transparent" Padding="18,14,14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" x:Name="HeaderDot" Width="14" Height="14" CornerRadius="7" Background="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ReportTitle" Text="Mod Analysis Report" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ReportFileName" Text="" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="6" Padding="10,3" Background="{DynamicResource HoverOverlay}" Margin="0,0,10,0">
                            <TextBlock x:Name="ScoreLabel" Text="Score: 0" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="VerdictLabel" Text="Unknown" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center" Foreground="Gray" Margin="0,0,8,0"/>
                        <Button x:Name="CloseBtn" Content="×" Width="34" Height="34"
                                FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand"
                                Click="CloseBtn_Click" ToolTip="Close (Esc)">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FF0000"/>
                                            <Setter Property="Foreground" Value="#FFFF4444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab bar -->
            <TabControl Grid.Row="1" x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged"
                        Background="Transparent" BorderThickness="0"
                        Padding="18,6,18,0"
                        FontSize="12">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="Padding" Value="14,8,14,8"/>
                        <Setter Property="Margin" Value="0,0,2,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Grid>
                                        <Border x:Name="Border" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                Background="Transparent" BorderThickness="0">
                                            <TextBlock Text="{TemplateBinding Header}" FontSize="12"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        <Border x:Name="AccentLine" Height="2" CornerRadius="1" HorizontalAlignment="Stretch"
                                                Margin="8,0,8,0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource AccentSolidBrush}" Opacity="0"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverOverlay}"/>
                                            <Setter TargetName="AccentLine" Property="Opacity" Value="1"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverOverlay}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- TAB 1: Detection Report -->
                <TabItem x:Name="TabReport" Header="Detection Report">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,0,0">
                        <StackPanel x:Name="ReportBody" Margin="0,0,6,0">
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB 2: Class Browser -->
                <TabItem x:Name="TabClasses" Header="Class Browser">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="ClassListTitle" Text="Classes" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,2,0,6"/>
                                <ListBox Grid.Row="1" x:Name="ClassListBox"
                                         Background="Transparent" BorderThickness="0"
                                         SelectionChanged="ClassListBox_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="4,3"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                                Background="Transparent" BorderThickness="0">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlay}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlay}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="11" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="ClassDetailName" Text="Select a class" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                    <TextBlock x:Name="ClassDetailVer" Text="" FontSize="10" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ClassDetailCount" Text="" FontSize="10" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" x:Name="ClassStringsList"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,1,0,1"
                                                                Background="#08FFFFFF" BorderThickness="0">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 3: ZIP Structure -->
                <TabItem x:Name="TabStructure" Header="ZIP Structure">
                    <Grid Margin="0,10,0,0">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="StructStats" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="1" x:Name="StructureBox"
                                         Style="{StaticResource MultilineTextBox}"
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 4: Metadata -->
                <TabItem x:Name="TabMetadata" Header="Metadata">
                    <Grid Margin="0,10,0,0">
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="MetaTitle" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="1" x:Name="MetadataBox"
                                         Style="{StaticResource MultilineTextBox}"
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Bottom bar with card style -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackground}" 
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14" Padding="18,8,18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="LegendDotHigh" Width="8" Height="8" CornerRadius="4" Background="#FF4444" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LegendBanned" Text="High Suspicion" FontSize="10" Foreground="#FF4444" Margin="4,0,14,0" VerticalAlignment="Center"/>
                        <Border x:Name="LegendDotSusp" Width="8" Height="8" CornerRadius="4" Background="#FFAA00" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LegendSusp" Text="Suspicious" FontSize="10" Foreground="#FFAA00" Margin="4,0,14,0" VerticalAlignment="Center"/>
                        <Border x:Name="LegendDotNorm" Width="8" Height="8" CornerRadius="4" Background="#44AA44" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LegendClean" Text="Normal" FontSize="10" Foreground="#44AA44" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ExportBtn" Content="💾 Save Report" Height="30"
                                MinWidth="120" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,8,0" Click="ExportBtn_Click"/>
                        <Button x:Name="LuytenBtn" Content="☕ Open with Luyten" Height="30"
                                MinWidth="150" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,8,0" Click="LuytenBtn_Click"/>
                        <Button x:Name="ExtractBtn" Content="📦 Extract JAR..." Height="30"
                                MinWidth="130" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,8,0" Click="ExtractBtn_Click"/>
                        <Button x:Name="CloseBtn2" Content="× Close" MinWidth="110" Height="30" Padding="10,0"
                                Style="{DynamicResource PrimaryButton}" FontSize="12" Click="CloseBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>