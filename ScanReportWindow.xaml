<Window x:Class="FMTool.ScanReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Report" Height="520" Width="640"
        MinWidth="540" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Segoe UI Variable, Segoe UI"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="14" GlassFrameThickness="0" UseAeroCaptionButtons="False" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with close button -->
            <Border Grid.Row="0" Background="Transparent" Padding="18,14,12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" x:Name="HeaderDot" Width="14" Height="14" CornerRadius="7" Background="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ReportTitle" Text="File Report" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ReportFileName" Text="" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="2" x:Name="CloseBtn" Content="×" Width="34" Height="34"
                            FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Cursor="Hand"
                            Click="CloseBtn_Click" ToolTip="Close (Esc)">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#33FF0000"/>
                                        <Setter Property="Foreground" Value="#FFFF4444"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- Status card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="18,0,18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="StatusTitle" Text="Status" FontSize="10" Foreground="Gray"/>
                        <TextBlock x:Name="StatusLabel" Text="Unknown" FontSize="15" FontWeight="Bold"
                                   Foreground="Gray" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TypeTitle" Text="Type" FontSize="10" Foreground="Gray"/>
                        <TextBlock x:Name="TypeLabel" Text="-" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="SizeTitle" Text="Size" FontSize="10" Foreground="Gray"/>
                        <TextBlock x:Name="SizeLabel" Text="-" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Details -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="18,0,18,0">
                <Border Style="{StaticResource Card}" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="DetailTitle" Text="File Information" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblName" Text="Name:" FontSize="11" Foreground="Gray" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailName" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="10,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblPath" Text="Path:" FontSize="11" Foreground="Gray" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailPath" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="10,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblType" Text="Type:" FontSize="11" Foreground="Gray"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailType" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="10,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblHash" Text="SHA-256:" FontSize="11" Foreground="Gray" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailHash" Text="" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" FontFamily="Consolas" Margin="10,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" x:Name="LblVerdict" Text="Verdict:" FontSize="11" Foreground="Gray" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetailVerdict" Text="" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Action buttons -->
            <Border Grid.Row="3" Background="{DynamicResource CardBackground}" 
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14" Padding="18,12,18,16">
                <StackPanel>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button x:Name="OpenFolderBtn" Content="📂 Open Folder" Height="30" MinWidth="120" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,6,0" Click="OpenFolder_Click"/>
                        <Button x:Name="CopyPathBtn" Content="📋 Copy Path" Height="30" MinWidth="110" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,6,0" Click="CopyPath_Click"/>
                        <Button x:Name="CopyHashBtn" Content="🔑 Copy SHA-256" Height="30" MinWidth="130" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,6,0" Click="CopyHash_Click"/>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="SendToModBtn" Content="🔍 Analyze in Mod Checker" Height="30" MinWidth="200" Padding="10,0"
                                Style="{DynamicResource GhostButton}" Margin="0,0,6,0" Click="SendToModChecker_Click"
                                Visibility="Visible"/>
                        <Button x:Name="CloseBtn2" Content="× Close" Width="110" Height="30" Padding="10,0"
                                Style="{DynamicResource PrimaryButton}" FontSize="12" Click="CloseBtn_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>