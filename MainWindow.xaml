<Window x:Class="FMTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FMTool" Height="770" Width="1260"
        MinHeight="640" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Segoe UI Variable, Segoe UI"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="18" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" ClipToBounds="True">
        <Grid>
            <!-- Background grid pattern (subtle) -->
            <Grid.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute" Opacity="0.6">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Geometry="M0,0 L40,0 M0,0 L0,40">
                            <GeometryDrawing.Pen>
                                <Pen Brush="{DynamicResource GridLineBrush}" Thickness="1"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ SIDEBAR ============ -->
            <Border x:Name="Sidebar" Grid.Column="0" Width="76"
                    Background="{DynamicResource SidebarBackground}" CornerRadius="18,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.35" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Grid Grid.Row="0" Margin="0,22,0,12" Height="42">
                        <Grid Width="42" Height="42" HorizontalAlignment="Center">
                            <Ellipse Margin="-4" Fill="{DynamicResource GlowBrush}" Opacity="0.5">
                                <Ellipse.Effect><BlurEffect Radius="16"/></Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Fill="{DynamicResource AccentBrushVertical}"/>
                            <Ellipse Margin="2.5">
                                <Ellipse.Fill><ImageBrush ImageSource="Resources/Circle.png" Stretch="UniformToFill"/></Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Stroke="#40FFFFFF" StrokeThickness="1.2"/>
                            <Ellipse Margin="-3" Stroke="{DynamicResource AccentSolidBrush}" StrokeThickness="1.5" Opacity="0.5"/>
                        </Grid>
                    </Grid>

                    <!-- Main nav -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,0">
                        <RadioButton x:Name="NavScanner" GroupName="Nav" Style="{StaticResource NavButton}" IsChecked="True" Checked="Nav_Checked" Tag="0">
                            <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="NavPrograms" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="1">
                            <TextBlock Text="🚀" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="NavPatterns" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="2">
                            <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="NavLogs" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="3">
                            <TextBlock Text="📜" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="NavModChecker" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="6">
                            <TextBlock Text="🛡️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton x:Name="NavChangelog" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="5">
                            <TextBlock Text="📰" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                    </StackPanel>

                    <!-- Settings at bottom -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,18">
                        <Rectangle Height="1" Fill="{DynamicResource CardBorderBrush}" Margin="16,0,16,8"/>
                        <RadioButton x:Name="NavSettings" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Nav_Checked" Tag="4">
                            <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RadioButton>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ MAIN AREA ============ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Menu toggle + page title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="22,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Scanner" Style="{StaticResource HeadingLarge}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Center: search bar (Spotify-style) -->
                    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320" Width="320">
                        <Border CornerRadius="8" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Height="38">
                            <Grid Margin="8,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox x:Name="FuncSearchBox" Grid.Column="1"
                                         MinHeight="0" MaxHeight="38"
                                         BorderThickness="0" Padding="6,0"
                                         Background="Transparent"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         TextChanged="FuncSearch_TextChanged" Tag="searchfunc"/>
                                <TextBlock Grid.Column="2" x:Name="SearchClearBtn" Text="✕" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Cursor="Hand" Margin="2,0,0,0"
                                           MouseLeftButtonDown="SearchClear_Click" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=FuncSearchBox}" Placement="Bottom"
                               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Slide" HorizontalOffset="-80" VerticalOffset="4" Width="460">
                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="4" MinWidth="440" MaxHeight="400">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.3" Color="Black"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="SearchResultPanel"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Right: window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Button x:Name="ThemeToggle" Style="{StaticResource IconButton}" Content="🎨" Click="ThemeToggle_Click" ToolTip="Theme"/>
                        <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=ThemeToggle}" Placement="Bottom"
                               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade" HorizontalOffset="-170" VerticalOffset="6">
                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="6" Width="190">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.35" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Choose theme" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="10,6,0,6"/>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Dark" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FF5C6BC0" VerticalAlignment="Center"/><TextBlock Text="Dark" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Arctic" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FF2DD4FF" VerticalAlignment="Center"/><TextBlock Text="Arctic" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Emerald" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FF3CC88C" VerticalAlignment="Center"/><TextBlock Text="Emerald" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Rose" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FFDC7896" VerticalAlignment="Center"/><TextBlock Text="Rose" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Cherry" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FFE65050" VerticalAlignment="Center"/><TextBlock Text="Cherry" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Gold" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FFE6B428" VerticalAlignment="Center"/><TextBlock Text="Gold" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="34" Margin="2" HorizontalContentAlignment="Left" Tag="Violet" Click="ThemeOption_Click">
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#FF9D2DFF" VerticalAlignment="Center"/><TextBlock Text="Violet" Margin="10,0,0,0"/></StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button x:Name="LangToggle" Style="{StaticResource IconButton}" Content="EN" FontSize="13" FontWeight="Bold" Click="LangToggle_Click" ToolTip="Language"/>
                        <Popup x:Name="LangPopup" PlacementTarget="{Binding ElementName=LangToggle}" Placement="Bottom"
                               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade" HorizontalOffset="-150" VerticalOffset="6">
                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="6" Width="190">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.35" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock x:Name="LangPopupTitle" Text="Language" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="10,6,0,6"/>
                                    <Button Style="{StaticResource GhostButton}" Height="38" Margin="2" HorizontalContentAlignment="Left" Tag="0" Click="LangOption_Click">
                                        <TextBlock Text="English" Margin="10,0,0,0" Padding="0,2,0,0"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Height="38" Margin="2" HorizontalContentAlignment="Left" Tag="1" Click="LangOption_Click">
                                        <TextBlock Text="Русский" Margin="10,0,0,0" Padding="0,2,0,0"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Border Width="1" Height="20" Background="{DynamicResource CardBorderBrush}" Margin="6,0"/>
                        <Button x:Name="MinBtn" Style="{StaticResource IconButton}" Content="—" Click="MinBtn_Click"/>
                        <Button x:Name="MaxBtn" Style="{StaticResource IconButton}" Content="☐" Click="MaxBtn_Click"/>
                        <Button x:Name="CloseBtn" Style="{StaticResource IconButton}" Content="✕" Click="CloseBtn_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Content -->
                <Grid Grid.Row="1" Margin="26,6,26,10">

                    <!-- ===== SCANNER ===== -->
                    <Grid x:Name="PageScanner" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock x:Name="FiltersTitle" Text="Scan Options" Style="{StaticResource HeadingMedium}" Margin="0,0,0,16"/>

                                    <TextBlock x:Name="ScanTypeLabel" Text="File type" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ScanTypeCombo" Style="{StaticResource ModernComboBox}" SelectedIndex="0" Margin="0,0,0,14" SelectionChanged="Filter_SelectionChanged">
                                        <ComboBoxItem Content=".exe / .jar / .dll"/>
                                        <ComboBoxItem Content=".exe"/>
                                        <ComboBoxItem Content=".jar"/>
                                        <ComboBoxItem Content=".dll"/>
                                    </ComboBox>

                                    <TextBlock x:Name="NameFilterLabel" Text="Name / pattern filter" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="NameFilterBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14" TextChanged="Filter_TextChanged"/>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="MinSizeLabel" Text="Min MB" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="MinSizeBox" Style="{StaticResource ModernTextBox}" Text="0" TextChanged="Filter_TextChanged"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock x:Name="MaxSizeLabel" Text="Max MB" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="MaxSizeBox" Style="{StaticResource ModernTextBox}" Text="500" TextChanged="Filter_TextChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock x:Name="TargetLabel" Text="Scan targets" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="ScanCDrive" Style="{StaticResource ModernCheckBox}" IsChecked="True" Content="C:\" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ScanDesktop" Style="{StaticResource ModernCheckBox}" IsChecked="True" Content="Desktop / Downloads" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="UsePatternMatch" Style="{StaticResource ModernCheckBox}" Content="Match cheat patterns" Margin="0,0,0,8" Click="Filter_Changed"/>
                                    <CheckBox x:Name="OnlySuspiciousCheck" Style="{StaticResource ModernCheckBox}" Content="Only suspicious" Margin="0,0,0,8" Click="Filter_Changed"/>
                                    <CheckBox x:Name="DeepScanCheck" Style="{StaticResource ModernCheckBox}" Content="Deep scan (contents)" Margin="0,0,0,14"/>

                                    <Button x:Name="PickFolderBtn" Style="{StaticResource GhostButton}" Content="Add custom folder..." Click="PickFolder_Click" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CustomFolderText" Grid.Column="0" Text="" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button x:Name="ClearFolderBtn" Grid.Column="1" Style="{StaticResource IconButton}" Width="26" Height="26" FontSize="13"
                                                Content="✕" Click="ClearFolder_Click" ToolTip="Remove folder"/>
                                    </Grid>

                                    <Button x:Name="StartScanBtn" Style="{StaticResource PrimaryButton}" Content="Start Scan" Click="StartScan_Click" Margin="0,0,0,10"/>
                                    <Button x:Name="StopScanBtn" Style="{StaticResource DangerButton}" Content="Stop" Click="StopScan_Click" IsEnabled="False" Margin="0,0,0,10"/>
                                    <Button x:Name="ExportBtn" Style="{StaticResource GhostButton}" Content="Export results" Click="Export_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14"
                                AllowDrop="True" Drop="ResultsPanel_Drop" DragOver="ResultsPanel_DragOver" DragLeave="ResultsPanel_DragLeave">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="4,0,4,10">
                                    <TextBlock x:Name="ResultsTitle" Text="Results" Style="{StaticResource HeadingMedium}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ResultsCount" Text="0" Style="{StaticResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="ScanProgress" Grid.Row="1" Style="{StaticResource ModernProgressBar}" IsIndeterminate="False" Margin="4,0,4,10" Visibility="Collapsed"/>
                                <ListView x:Name="ResultsList" Grid.Row="2" Style="{StaticResource ModernListView}"
                                          ItemContainerStyle="{StaticResource ModernListViewItem}" MouseDoubleClick="ResultsList_DoubleClick" Loaded="ResultsList_Loaded"
                                          PreviewMouseRightButtonDown="ResultsList_PreviewMouseRightButtonDown"
                                          SelectionChanged="ResultsList_SelectionChanged">
                                    <ListView.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="8,4" Margin="0,2,0,2" Background="{DynamicResource HoverOverlay}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Tag}" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListView.GroupStyle>
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="CtxOpenFolder" Header="" Click="OpenFolder_Click"/>
                                            <MenuItem x:Name="CtxCopyPath" Header="" Click="CopyPath_Click"/>
                                            <MenuItem x:Name="CtxCopyHash" Header="" Click="CopyHash_Click"/>
                                            <Separator/>
                                            <MenuItem x:Name="CtxSendToModChecker" Header="" Click="SendToModChecker_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView ColumnHeaderContainerStyle="{StaticResource ModernGridViewColumnHeader}">
                                            <GridViewColumn Header=" " Width="50">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Border x:Name="ScanBtnBorder" CornerRadius="6"
                                                                    Background="{DynamicResource CardBackground}"
                                                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                                                    BorderThickness="1"
                                                                    Width="34" Height="26"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    RenderTransformOrigin="0.5,0.5">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsJarOrZip}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                                <Setter Property="Opacity" Value="0.4"/>
                                                                            </DataTrigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Opacity" Value="0.85"/>
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Button Content="🔍" FontSize="13"
                                                                        Style="{DynamicResource GhostButton}"
                                                                        ToolTip="{Binding AnalyzeTooltip}"
                                                                        Click="RowSendToModChecker_Click"
                                                                        Background="Transparent"
                                                                        Padding="0"
                                                                        Width="30" Height="22"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" Width="220" DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeText}"/>
                                            <GridViewColumn Header="Type" Width="60" DisplayMemberBinding="{Binding Ext}"/>
                                            <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding StatusText}"/>
                                            <GridViewColumn Header="Path" Width="330" DisplayMemberBinding="{Binding Path}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <Border x:Name="ScanDetailPanel" Grid.Row="3" CornerRadius="8" Padding="12" Margin="0,8,0,0"
                                        Background="{DynamicResource InputBackground}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ScanDetailDot" Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                Background="Gray" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="ScanDetailName" FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="ScanDetailStatus" FontSize="12" FontWeight="Bold"
                                                       Foreground="Gray" Margin="0,2,0,0"/>
                                            <TextBlock x:Name="ScanDetailPath" Style="{StaticResource MutedText}" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            <TextBlock x:Name="ScanDetailSize" Style="{StaticResource MutedText}" FontSize="11"/>
                                            <TextBlock x:Name="ScanDetailType" Style="{StaticResource MutedText}" FontSize="11"/>
                                            <Button x:Name="ScanDetailModCheck" Style="{StaticResource GhostButton}" FontSize="11"
                                                    Padding="8,4" Margin="0,6,0,0"
                                                    Click="ScanDetailModCheck_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== PROGRAMS ===== -->
                    <Grid x:Name="PagePrograms" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="4,0,4,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="ProgramsTitle" Text="Embedded Programs" Style="{StaticResource HeadingMedium}"/>
                                        <TextBlock x:Name="ProgramsHint" Text="Click a card to launch. Files are extracted from the app." Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="CloseAllBtn" Grid.Column="1" Style="{StaticResource DangerButton}" Width="220"
                                            VerticalAlignment="Top" Content="Close launched programs" Click="CloseAllPrograms_Click"/>
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ProgramsItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="250" Height="96" Margin="9" Cursor="Hand"
                                                        Click="ProgramCard_Click" Tag="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Border x:Name="glow" CornerRadius="16" Opacity="0"
                                                                        Background="{DynamicResource AccentBrush}">
                                                                    <Border.Effect><BlurEffect Radius="20"/></Border.Effect>
                                                                </Border>
                                                                <Border x:Name="cb" CornerRadius="16" Padding="16"
                                                                        Background="{DynamicResource CardBackground}"
                                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="54"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Icon holder -->
                                                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="13"
                                                                                Background="{DynamicResource InputBackground}"
                                                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                                                VerticalAlignment="Center">
                                                                            <Grid>
                                                                                <Image Source="{Binding IconPath}" Width="30" Height="30"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"/>
                                                                                <TextBlock Text="{Binding Ext}" FontSize="13" FontWeight="Bold"
                                                                                           Foreground="{DynamicResource AccentSolidBrush}"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                           Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13.5"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding Description}" FontSize="11.5"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="36" Margin="0,3,0,0"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="cb" Property="BorderBrush" Value="{DynamicResource AccentSolidBrush}"/>
                                                                    <Setter TargetName="glow" Property="Opacity" Value="0.28"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== PATTERNS ===== -->
                    <Grid x:Name="PagePatterns" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0" Padding="10">
                            <StackPanel x:Name="PatternButtons">
                                <TextBlock x:Name="PatternsListTitle" Text="Search Patterns" Style="{StaticResource HeadingMedium}" Margin="8,8,0,12"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PatternNameText" Grid.Row="0" Text="Select a pattern" Style="{StaticResource HeadingMedium}" Margin="0,0,0,12"/>
                                <TextBox x:Name="PatternContentBox" Grid.Row="1" Style="{StaticResource MultilineTextBox}" IsReadOnly="True" FontFamily="Consolas"/>
                                <Button x:Name="CopyPatternBtn" Grid.Row="2" Style="{StaticResource PrimaryButton}" Content="Copy to Clipboard"
                                        Click="CopyPattern_Click" HorizontalAlignment="Right" Width="190" Margin="0,14,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== LOGS ===== -->
                    <Grid x:Name="PageLogs" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                    <Button x:Name="PsLogBtn" Style="{StaticResource GhostButton}" Content="PowerShell History" Click="PsLog_Click"/>
                                </StackPanel>
                                <TextBox x:Name="LogsBox" Grid.Row="1" Style="{StaticResource MultilineTextBox}" IsReadOnly="True" FontFamily="Consolas"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button x:Name="CopyLogsBtn" Style="{StaticResource GhostButton}" Width="150" Margin="0,0,10,0" Content="Copy to Clipboard" Click="CopyLogs_Click"/>
                                    <Button x:Name="RefreshLogsBtn" Style="{StaticResource GhostButton}" Width="100" Content="Refresh" Click="RefreshLogs_Click" Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== SETTINGS ===== -->
                    <Grid x:Name="PageSettings" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock x:Name="SettingsTitle" Text="Settings" Style="{StaticResource HeadingMedium}" Margin="0,0,0,20"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
<TextBlock x:Name="ThemeLabel" Text="Theme" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
<ComboBox x:Name="ThemeCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" Width="220" HorizontalAlignment="Left" SelectedIndex="0" SelectionChanged="ThemeCombo_Changed">
    <ComboBoxItem Content="Dark"/>
    <ComboBoxItem Content="Arctic"/>
    <ComboBoxItem Content="Emerald"/>
    <ComboBoxItem Content="Rose"/>
    <ComboBoxItem Content="Cherry"/>
    <ComboBoxItem Content="Gold"/>
    <ComboBoxItem Content="Violet"/>
</ComboBox>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LanguageLabel" Text="Language" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="LangCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" Width="220" HorizontalAlignment="Left" SelectedIndex="0" SelectionChanged="LangCombo_Changed">
                                        <ComboBoxItem Content="English"/>
                                        <ComboBoxItem Content="Русский"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="AutostartLabel" Text="Auto-Startup" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox x:Name="AutostartCheck" Style="{StaticResource ModernCheckBox}" Content="Run at Windows startup" VerticalAlignment="Center" Click="AutostartCheck_Click"/>
                                    </StackPanel>
                                </Grid>

                                  <Grid Margin="0,0,0,16">
                                      <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="200"/>
                                          <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock x:Name="JavaLabel" Text="Java" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                          <Border x:Name="JavaStatusBadge" CornerRadius="6" Padding="12,5" Background="{DynamicResource HoverOverlay}"
                                                  BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                                              <StackPanel Orientation="Horizontal">
                                                  <TextBlock Text="☕" FontSize="14" VerticalAlignment="Center"/>
                                                  <TextBlock x:Name="JavaStatusText" Text="..." FontSize="13" FontWeight="SemiBold"
                                                             VerticalAlignment="Center" Margin="8,0,0,0"/>
                                              </StackPanel>
                                          </Border>
                                          <Button x:Name="InstallJavaBtn" Style="{StaticResource GhostButton}" Width="90" Margin="0,0,6,0" Content="Install" Click="InstallJava_Click"/>
                                          <Button x:Name="ReinstallJavaBtn" Style="{StaticResource GhostButton}" Width="90" Margin="0,0,6,0" Content="Reinstall" Click="ReinstallJava_Click"/>
                                          <Button x:Name="RemoveJavaBtn" Style="{StaticResource GhostButton}" Width="90" Content="Remove" Click="RemoveJava_Click"/>
                                        </StackPanel>
                                    </Grid>

                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,20"/>

                                <!-- Integration section -->
                                <TextBlock Text="Integration" Style="{StaticResource HeadingMedium}" Margin="0,0,0,14"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="CtxMenuLabel" Text="Explorer context menu" Style="{StaticResource BodyText}"/>
                                        <TextBlock x:Name="CtxMenuHint" Text="Right-click .jar → Scan with FMTool" Style="{StaticResource MutedText}" FontSize="11"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="RegisterCtxBtn" Style="{StaticResource GhostButton}" Content="Register" Width="80" Margin="0,0,6,0" Click="RegisterCtxBtn_Click"/>
                                        <Button x:Name="UnregisterCtxBtn" Style="{StaticResource GhostButton}" Content="Remove" Width="80" Click="UnregisterCtxBtn_Click"/>
                                    </WrapPanel>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="FileAssocLabel" Text="File association" Style="{StaticResource BodyText}"/>
                                        <TextBlock x:Name="FileAssocHint" Text="Open .jar files with FMTool by default" Style="{StaticResource MutedText}" FontSize="11"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="RegisterAssocBtn" Style="{StaticResource GhostButton}" Content="Register" Width="80" Margin="0,0,6,0" Click="RegisterAssocBtn_Click"/>
                                        <Button x:Name="UnregisterAssocBtn" Style="{StaticResource GhostButton}" Content="Remove" Width="80" Click="UnregisterAssocBtn_Click"/>
                                    </WrapPanel>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="62" Height="62">
                                        <Ellipse Margin="-8" Fill="{DynamicResource GlowBrush}" Opacity="0.5">
                                            <Ellipse.Effect><BlurEffect Radius="20"/></Ellipse.Effect>
                                        </Ellipse>
                                        <Border CornerRadius="31" ClipToBounds="True">
                                            <Grid>
                                                <Ellipse Fill="{DynamicResource AccentBrushVertical}"/>
                                                <Image Source="Resources/Circle.png" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="AboutTitle" Text="FMTool" Style="{StaticResource HeadingMedium}"/>
                                        <TextBlock x:Name="AboutVersion" Text="Version 1.0.0" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="AboutAuthor" Text="Author: zxc1337" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="AboutFooter" Text="Made for FunMoon Server" Style="{StaticResource MutedText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ===== CHANGELOG ===== -->
                    <Grid x:Name="PageChangelog" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="ChangelogPageTitle" Grid.Row="0" Text="Changelog" Style="{StaticResource HeadingMedium}" Margin="0,0,0,12"/>
                                <TextBox Grid.Row="1" x:Name="ChangelogBox" Style="{StaticResource MultilineTextBox}"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button x:Name="CopyChangelogBtn" Style="{StaticResource GhostButton}" Width="150" Margin="0,0,10,0"
                                            Content="Copy to Clipboard" Click="CopyChangelog_Click"/>
                                    <Button x:Name="ExportChangelogBtn" Style="{StaticResource PrimaryButton}" Width="180"
                                            Content="Export changelog" Click="ExportChangelog_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== MOD CHECKER ===== -->
                    <Grid x:Name="PageModChecker" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock x:Name="ModCheckerTitle" Text="Mod Checker" Style="{StaticResource HeadingMedium}" Margin="0,0,0,16"/>
                                <Border x:Name="DropZone" Height="140" CornerRadius="12"
                                        Background="{DynamicResource InputBackground}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="2"
                                        AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver" DragLeave="DropZone_DragLeave" MouseLeftButtonDown="DropZone_MouseClick">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="DropZoneText" Text="Drop .jar files here" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock x:Name="DropZoneHint" Text="or click to browse" Style="{StaticResource MutedText}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="BrowseModBtn" Style="{StaticResource GhostButton}" Content="Browse JAR files..." Click="BrowseMod_Click" Margin="0,14,0,0"/>
                                <Button x:Name="ClearModsBtn" Style="{StaticResource GhostButton}" Content="Clear" Click="ClearMods_Click" Margin="0,8,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="SaveHistoryBtn" Style="{StaticResource GhostButton}" Content="Save" Click="SaveHistory_Click" Width="80"/>
                                    <Button x:Name="LoadHistoryBtn" Style="{StaticResource GhostButton}" Content="Load" Click="LoadHistory_Click" Width="80" Margin="8,0,0,0"/>
                                </StackPanel>
                                <ProgressBar x:Name="ModProgressBar" Height="4" Margin="0,8,0,0" Foreground="{DynamicResource AccentSolidBrush}" Background="{DynamicResource InputBackground}" BorderThickness="0" Visibility="Collapsed" Maximum="100" Value="0"/>

                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,16,0,14"/>
                                <TextBlock x:Name="BannedListTitle" Text="Banned mods" Style="{StaticResource HeadingMedium}" Margin="0,0,0,8"/>
                                <TextBox x:Name="BannedModsFilter" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10" TextChanged="BannedModsFilter_TextChanged"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                                    <ItemsControl x:Name="BannedModsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" FontSize="11" Margin="0,1,0,1" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock x:Name="ModResultsTitle" Text="Results" Style="{StaticResource HeadingMedium}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ModResultsCount" Text="No files checked" Style="{StaticResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBox x:Name="ModFilterBox" Grid.Row="1" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8" TextChanged="ModFilterBox_TextChanged"/>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ModResultsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="10" Margin="0,0,0,6" Background="{DynamicResource InputBackground}">
                                                    <Border.ContextMenu>
                                                        <ContextMenu Loaded="ModContextMenu_Loaded">
                                                            <MenuItem Header="" Click="ModOpenReport_Click"/>
                                                            <MenuItem Header="" Click="ModOpenFolder_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="" Click="ModCopyPath_Click"/>
                                                            <MenuItem Header="" Click="ModCopyHash_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6" Background="{Binding Color}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="11" FontWeight="Bold"
                                                                   Foreground="{Binding Color}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Border Grid.Row="3" x:Name="ModDisclaimerBorder" CornerRadius="6" Padding="8,6" Background="#33FFAA00" Margin="0,8,0,0">
                                    <TextBlock x:Name="ModDisclaimer" Text="" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                <Border Grid.Row="2" Background="Transparent">
                    <Grid Margin="26,0,26,4">
                        <Border CornerRadius="10" Padding="12,6" Background="#CC14151A"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusText" Text="Ready" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <StackPanel x:Name="StatusDots" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border x:Name="StatusDotCheat" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatusCheatCount" Text="0" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="4,0,10,0"/>
                                        <Border x:Name="StatusDotSusp" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatusSuspCount" Text="0" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="4,0,10,0"/>
                                        <Border x:Name="StatusDotNorm" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatusNormalCount" Text="0" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="7" Padding="8,2" Background="{DynamicResource HoverOverlay}">
                                    <TextBlock x:Name="StatusFooterText" Text="by zxc1337 for FunMoon." FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentSolidBrush}" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== TOAST (centered across whole window) ===== -->
            <Border x:Name="Toast" Grid.Column="0" Grid.ColumnSpan="2"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,54" CornerRadius="14" Padding="18,13" Opacity="0" MinWidth="260"
                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="6" Direction="270" Opacity="0.35" Color="Black"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTr" Y="40"/>
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="ToastIconBox" Width="34" Height="34" CornerRadius="17"
                            Background="{DynamicResource HoverOverlay}" VerticalAlignment="Center">
                        <TextBlock x:Name="ToastIcon" Text="✓" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="ToastText" Text="" FontSize="13.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="14,0,6,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
