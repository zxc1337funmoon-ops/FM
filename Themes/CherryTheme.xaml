<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cherry Theme -->
    <Color x:Key="BackgroundStart">#FF1E0F0F</Color>
    <Color x:Key="BackgroundEnd">#FF180A0A</Color>
    <Color x:Key="SidebarStart">#FF261414</Color>
    <Color x:Key="SidebarEnd">#FF220F0F</Color>
    <Color x:Key="CardStart">#FF2D1919</Color>
    <Color x:Key="CardEnd">#FF281414</Color>
    <Color x:Key="CardBorderColor">#FF4C2D2D</Color>
    <Color x:Key="TextPrimaryColor">#FFFFF2F2</Color>
    <Color x:Key="TextSecondaryColor">#FFD4A8A8</Color>
    <Color x:Key="TextMutedColor">#FF8A6A6A</Color>
    <Color x:Key="AccentColor1">#FFE65050</Color>
    <Color x:Key="AccentColor2">#FFCA4040</Color>
    <Color x:Key="AccentColorHover">#FFEFA0A0</Color>
    <Color x:Key="DangerColor">#FFF04862</Color>
    <Color x:Key="SuccessColor">#FF32D296</Color>
    <Color x:Key="WarningColor">#FFFFC24B</Color>
    <Color x:Key="InputBackgroundColor">#FF170C0C</Color>
    <Color x:Key="HoverOverlayColor">#20E65050</Color>
    <Color x:Key="GridLineColor">#08FFFFFF</Color>
    <Color x:Key="GlowColor">#FFE65050</Color>

    <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BackgroundStart}" Offset="0"/>
        <GradientStop Color="{StaticResource BackgroundEnd}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarBackground" StartPoint="0,0" EndPoint="0.4,1">
        <GradientStop Color="{StaticResource SidebarStart}" Offset="0"/>
        <GradientStop Color="{StaticResource SidebarEnd}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CardStart}" Offset="0"/>
        <GradientStop Color="{StaticResource CardEnd}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource AccentColor2}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentColor1}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentBrushVertical" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor1}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentColor2}" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="AccentSolidBrush" Color="{StaticResource AccentColor1}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentColorHover}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="HoverOverlay" Color="{StaticResource HoverOverlayColor}"/>
    <SolidColorBrush x:Key="GridLineBrush" Color="{StaticResource GridLineColor}"/>
    <SolidColorBrush x:Key="GlowBrush" Color="{StaticResource GlowColor}"/>

    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="SidebarSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource HoverOverlayColor}"/>

</ResourceDictionary>